#!/system/bin/sh

# Shizuku+ SU Bridge (su wrapper)
# Allows legacy root apps to function via Shizuku+ privileges.
# Drop-in replacement for /system/bin/su for apps that support custom paths.

BASEDIR=$(dirname "$0")

# rish needs RISH_APPLICATION_ID to be a package that has Shizuku permission.
# Set it to Shizuku+ so rish can connect to the running Shizuku server.
export RISH_APPLICATION_ID="af.shizuku.plus.api"

# If no arguments are provided drop into an interactive rish shell
if [ "$1" = "" ]; then
    exec sh "$BASEDIR/rish"
fi

# Most common legacy app usage: su -c "command"
if [ "$1" = "-c" ]; then
    shift
    exec sh "$BASEDIR/rish" -c "$*"
fi

# su <user> -c "command" — ignore the user argument, pass command to rish
if [ "$2" = "-c" ]; then
    shift 2
    exec sh "$BASEDIR/rish" -c "$*"
fi

# Fallback: pass all arguments to rish
exec sh "$BASEDIR/rish" "$@"
