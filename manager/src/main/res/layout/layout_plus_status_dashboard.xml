<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="16dp"
    android:layout_marginBottom="8dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="?colorSurfaceContainerLow"
    app:strokeWidth="1dp"
    app:strokeColor="?colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active Enhancements Dashboard"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?colorPrimary"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- 2x3 Grid of Status Items -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <!-- Item 1: Storage Bridge -->
            <LinearLayout
                android:id="@+id/dash_storage_bridge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_margin="4dp"
                android:background="@drawable/shape_node_inactive"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dot_storage_bridge"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_status_indicator" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Storage Bridge"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface" />
            </LinearLayout>

            <!-- Item 2: Process Control -->
            <LinearLayout
                android:id="@+id/dash_process_control"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_margin="4dp"
                android:background="@drawable/shape_node_inactive"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dot_process_control"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_status_indicator" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Process Control"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface" />
            </LinearLayout>

            <!-- Item 3: AI Bridge -->
            <LinearLayout
                android:id="@+id/dash_ai_bridge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_margin="4dp"
                android:background="@drawable/shape_node_inactive"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dot_ai_bridge"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_status_indicator" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="AI Bridge"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface" />
            </LinearLayout>

            <!-- Item 4: VM Manager -->
            <LinearLayout
                android:id="@+id/dash_vm_manager"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_margin="4dp"
                android:background="@drawable/shape_node_inactive"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dot_vm_manager"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_status_indicator" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="VM Manager"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface" />
            </LinearLayout>

            <!-- Item 5: DNS Governor -->
            <LinearLayout
                android:id="@+id/dash_dns_governor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_margin="4dp"
                android:background="@drawable/shape_node_inactive"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dot_dns_governor"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_status_indicator" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="DNS Governor"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface" />
            </LinearLayout>

            <!-- Item 6: Shell Accelerator -->
            <LinearLayout
                android:id="@+id/dash_shell_accelerator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_margin="4dp"
                android:background="@drawable/shape_node_inactive"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dot_shell_accelerator"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_status_indicator" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Shell Accelerator"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface" />
            </LinearLayout>

        </GridLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
