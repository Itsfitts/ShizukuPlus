<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="16dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="?colorSurfaceContainerLow"
    app:strokeWidth="1dp"
    app:strokeColor="?colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <!-- Visual Flow Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Node 1: App -->
            <LinearLayout
                android:id="@+id/flow_node_app"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_inactive">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_devices_24"
                    android:tint="?colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App"
                    android:textSize="9sp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Line/Arrow 1 -->
            <View
                android:id="@+id/flow_line_1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="4dp"
                android:layout_marginHorizontal="8dp"
                android:background="?colorOutlineVariant" />

            <!-- Node 2: Storage Bridge -->
            <LinearLayout
                android:id="@+id/flow_node_bridge"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_inactive">
                <ImageView
                    android:id="@+id/bridge_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_bolt_24"
                    android:tint="?colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bridge"
                    android:textSize="9sp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Line/Arrow 2 -->
            <View
                android:id="@+id/flow_line_2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="4dp"
                android:layout_marginHorizontal="8dp"
                android:background="?colorOutlineVariant" />

            <!-- Node 3: Storage -->
            <LinearLayout
                android:id="@+id/flow_node_storage"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_inactive">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_folder_24"
                    android:tint="?colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SDCard"
                    android:textSize="9sp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Dynamic Status Explanation -->
        <TextView
            android:id="@+id/flow_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Storage Bridge is currently disabled. File access routes directly via slow Android SAF API."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?colorOnSurfaceVariant"
            android:textAlignment="center" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
