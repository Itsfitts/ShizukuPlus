<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Card.Small">

    <ImageView
        android:id="@android:id/icon"
        style="@style/CardIcon.Droplet"
        android:duplicateParentState="true"
        android:importantForAccessibility="yes"
        android:contentDescription="@string/accessibility_icon_server_status"
        android:transitionName="icon_server_status"
        android:src="@drawable/ic_server_error_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.5" />

    <!--
      Vertical LinearLayout for text/chip content.
      Using LinearLayout instead of a nested ConstraintLayout means layout_marginTop
      on child views is always honoured, and the status dot in the title row reliably
      aligns with the first line of text regardless of font scale.
      (The inner ConstraintLayout approach caused overlap on Nothing 4a / Android 16
      with large font scale because marginTop on a top+bottom-constrained view is
      ignored — issue #271.)
    -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/m3e_spacing_large"
        android:layout_marginEnd="16dp"
        android:duplicateParentState="true"
        app:layout_constraintStart_toEndOf="@android:id/icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Status dot + title on one horizontal row, gravity=center_vertical
             so the dot always optically aligns with the text cap-height. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:duplicateParentState="true">

            <View
                android:id="@+id/status_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/shape_status_indicator" />

            <TextView
                android:id="@android:id/text1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="?textAppearanceTitleLarge"
                android:textColor="?colorOnSurface"
                android:lineSpacingExtra="1sp"
                android:duplicateParentState="true"
                tools:text="Running (version 10)" />

        </LinearLayout>

        <TextView
            android:id="@android:id/text2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?textAppearanceLabelLarge"
            android:textColor="?colorOnSurfaceVariant"
            android:lineSpacingExtra="1sp"
            android:duplicateParentState="true" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/status_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/btn_activity_log"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_activity_log"
                android:visibility="gone"
                app:chipIcon="@drawable/ic_article_24"
                tools:visibility="visible" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btn_diagnostics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diagnostics"
                android:visibility="gone"
                app:chipIcon="@drawable/ic_server_ok_24"
                tools:visibility="visible" />

        </com.google.android.material.chip.ChipGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sentry_offline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/sentry_offline_notice_button"
            android:visibility="gone"
            android:textColor="?colorError"
            tools:visibility="visible" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>