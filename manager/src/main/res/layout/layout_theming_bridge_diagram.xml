<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="16dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="?colorSurfaceContainerLow"
    app:strokeWidth="1dp"
    app:strokeColor="?colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="80dp">

            <!-- Node 1: System UI Theme -->
            <LinearLayout
                android:id="@+id/theme_node_sys"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_inactive">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_window_24"
                    android:tint="?colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stock UI"
                    android:textSize="9sp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Line 1 -->
            <View
                android:id="@+id/theme_line_1"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/theme_node_sys"
                android:layout_toStartOf="@+id/theme_node_bridge"
                android:layout_marginHorizontal="8dp"
                android:background="?colorOutlineVariant" />

            <!-- Node 2: Theme Bridge -->
            <LinearLayout
                android:id="@+id/theme_node_bridge"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_inactive">
                <ImageView
                    android:id="@+id/theme_bridge_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_palette_24"
                    android:tint="?colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OMT Bridge"
                    android:textSize="9sp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Line 2 -->
            <View
                android:id="@+id/theme_line_2"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/theme_node_bridge"
                android:layout_toStartOf="@+id/theme_node_custom"
                android:layout_marginHorizontal="8dp"
                android:background="?colorOutlineVariant" />

            <!-- Node 3: Custom/Styled UI -->
            <LinearLayout
                android:id="@+id/theme_node_custom"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_inactive">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_suggest_24"
                    android:tint="?colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Styled UI"
                    android:textSize="9sp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textStyle="bold" />
            </LinearLayout>

        </RelativeLayout>

        <!-- Status Explanation -->
        <TextView
            android:id="@+id/theme_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Theming Bridge is disabled. Stock UI elements are shown."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?colorOnSurfaceVariant"
            android:textAlignment="center" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
