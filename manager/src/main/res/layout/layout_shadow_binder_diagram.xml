<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="16dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="?colorSurfaceContainerLow"
    app:strokeWidth="1dp"
    app:strokeColor="?colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <!-- Flow Visuals -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="80dp">

            <!-- Node 1: Requesting App -->
            <LinearLayout
                android:id="@+id/shadow_node_app"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_active">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_devices_24"
                    android:tint="?colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Query App"
                    android:textSize="9sp"
                    android:textColor="?colorPrimary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Line 1 -->
            <View
                android:id="@+id/shadow_line_1"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/shadow_node_app"
                android:layout_toStartOf="@+id/shadow_node_mask"
                android:layout_marginHorizontal="8dp"
                android:background="?colorPrimary" />

            <!-- Node 2: Shadow Mask -->
            <LinearLayout
                android:id="@+id/shadow_node_mask"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_active">
                <ImageView
                    android:id="@+id/mask_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_shield_24"
                    android:tint="?colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cloaking"
                    android:textSize="9sp"
                    android:textColor="?colorPrimary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Line 2 -->
            <View
                android:id="@+id/shadow_line_2"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/shadow_node_mask"
                android:layout_toStartOf="@+id/shadow_node_packages"
                android:layout_marginHorizontal="8dp"
                android:background="?colorOutlineVariant" />

            <!-- Node 3: Hidden Packages -->
            <LinearLayout
                android:id="@+id/shadow_node_packages"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_inactive">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_visibility_off_24"
                    android:tint="?colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hidden App"
                    android:textSize="9sp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textStyle="bold" />
            </LinearLayout>

        </RelativeLayout>

        <!-- Status Explanation -->
        <TextView
            android:id="@+id/shadow_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Shadow Binder is active. Selected packages are cloaked and invisible to querying apps."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?colorOnSurfaceVariant"
            android:textAlignment="center" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
