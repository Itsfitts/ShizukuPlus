<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="16dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="?colorSurfaceContainerLow"
    app:strokeWidth="1dp"
    app:strokeColor="?colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <!-- Flow Visuals -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Node 1: Shell Tasks -->
            <LinearLayout
                android:id="@+id/ai_node_shell"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_active">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_terminal_24"
                    android:tint="?colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shell Tasks"
                    android:textSize="9sp"
                    android:textColor="?colorPrimary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Line 1 -->
            <View
                android:id="@+id/ai_line_1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="4dp"
                android:layout_marginHorizontal="8dp"
                android:background="?colorPrimary" />

            <!-- Node 2: AI Accelerator -->
            <LinearLayout
                android:id="@+id/ai_node_core"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_active">
                <ImageView
                    android:id="@+id/ai_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_bolt_24"
                    android:tint="?colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Accelerator"
                    android:textSize="9sp"
                    android:textColor="?colorPrimary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Line 2 -->
            <View
                android:id="@+id/ai_line_2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="4dp"
                android:layout_marginHorizontal="8dp"
                android:background="?colorOutlineVariant" />

            <!-- Node 3: Touch Automation -->
            <LinearLayout
                android:id="@+id/ai_node_npu"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_node_inactive">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_integration_instructions_24"
                    android:tint="?colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Automation"
                    android:textSize="9sp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Status Explanation -->
        <TextView
            android:id="@+id/ai_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="AI Bridge is currently disabled. Shell task optimizations route via standard execution threads."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?colorOnSurfaceVariant"
            android:textAlignment="center" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
