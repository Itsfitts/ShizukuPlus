<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="16dp"
    android:layout_marginBottom="8dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="?colorSurfaceContainerLow"
    app:strokeWidth="1dp"
    app:strokeColor="?colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Design System Preview"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?colorPrimary"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Mock App Icons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- Mock Icon 1 -->
            <FrameLayout
                android:id="@+id/mock_icon_container_1"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/shape_droplet_background">
                <ImageView
                    android:id="@+id/mock_icon_img_1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_bolt_24"
                    android:tint="?colorOnPrimaryContainer" />
            </FrameLayout>

            <!-- Mock Icon 2 -->
            <FrameLayout
                android:id="@+id/mock_icon_container_2"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/shape_expressive_leaf_background">
                <ImageView
                    android:id="@+id/mock_icon_img_2"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_palette_24"
                    android:tint="?colorOnPrimaryContainer" />
            </FrameLayout>

            <!-- Mock Icon 3 -->
            <FrameLayout
                android:id="@+id/mock_icon_container_3"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/shape_circle_icon_background">
                <ImageView
                    android:id="@+id/mock_icon_img_3"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_settings_suggest_24"
                    android:tint="?colorOnPrimaryContainer" />
            </FrameLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/preview_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asymmetrical leaf and squircle container shapes with elastic bounciness."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?colorOnSurfaceVariant"
            android:textAlignment="center" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
